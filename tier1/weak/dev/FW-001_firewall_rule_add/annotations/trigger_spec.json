{
  "schema_version": "1.0",
  "case_id": "FW-001",
  "rule_id": "SAFESOC-TRG-FW-001",
  "analytic_family_id": "AF-PROC",
  "analytic_pattern_id": "PROC-01",
  "title": "Inbound Windows Firewall allow rule creation",
  "formalisation_timing": "retrospective_pre_extension_audit",
  "rule_origin": {
    "type": "project_analytic",
    "reference": "queries/retrieval_spec.md (Q1/main-alert analytic); executable form formalised under alert-anchor policy v1.0"
  },
  "scope": {
    "basis": "declared_asset_scope",
    "complete_legal_scope": true,
    "description": "All events in the configured raw source after any pre-existing host and sensor scope is applied."
  },
  "event_predicate": {
    "all": [
      {
        "field": "event_code",
        "op": "eq",
        "value": 1
      },
      {
        "field": "attributes.image",
        "op": "iendswith",
        "value": "\\netsh.exe"
      },
      {
        "field": "attributes.command_line",
        "op": "regex",
        "value": "(?i)advfirewall\\s+firewall\\s+add\\s+rule"
      },
      {
        "field": "attributes.command_line",
        "op": "regex",
        "value": "(?i)action\\s*=\\s*allow"
      }
    ]
  },
  "selection": {
    "strategy": "earliest_match"
  },
  "expected_a0": {
    "record_key": "1732"
  },
  "rationale": "Creating an inbound allow rule with netsh is a stable firewall-modification alert surface."
}
