{
  "schema_version": "1.0",
  "case_id": "BF-001",
  "rule_id": "SAFESOC-TRG-BF-001",
  "analytic_family_id": "AF-AUTH",
  "analytic_pattern_id": "AUTH-01",
  "title": "Burst of inbound RDP connections from one source",
  "formalisation_timing": "retrospective_pre_extension_audit",
  "rule_origin": {
    "type": "project_analytic",
    "reference": "queries/retrieval_spec.md (Q1/main-alert analytic); executable form formalised under alert-anchor policy v1.0"
  },
  "scope": {
    "basis": "full_source",
    "complete_legal_scope": true,
    "description": "All events in the configured raw source; no event-level answer selector is applied."
  },
  "event_predicate": {
    "all": [
      {
        "field": "event_code",
        "op": "eq",
        "value": 3
      },
      {
        "field": "attributes.destination_port",
        "op": "eq",
        "value": "3389"
      },
      {
        "field": "attributes.initiated",
        "op": "ieq",
        "value": "false"
      }
    ]
  },
  "selection": {
    "strategy": "earliest_in_highest_count_group"
  },
  "expected_a0": {
    "record_key": "4816"
  },
  "rationale": "The alert is generated by an inbound RDP burst, not by a hand-picked individual network event; A0 is the earliest representative event in the largest qualifying group.",
  "aggregation": {
    "group_by": [
      "attributes.source_ip",
      "attributes.destination_ip",
      "attributes.destination_port"
    ],
    "count_gte": 10,
    "within_seconds_lte": 600,
    "distinct": {
      "field": "attributes.source_port",
      "count_gte": 10
    }
  }
}
