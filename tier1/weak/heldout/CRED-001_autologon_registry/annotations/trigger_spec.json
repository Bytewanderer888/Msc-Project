{
  "schema_version": "1.0",
  "case_id": "CRED-001",
  "rule_id": "SAFESOC-TRG-CRED-001",
  "analytic_family_id": "AF-REG",
  "analytic_pattern_id": "REG-01",
  "title": "Winlogon default-user registry modification",
  "formalisation_timing": "retrospective_pre_extension_audit",
  "rule_origin": {
    "type": "project_analytic",
    "reference": "queries/retrieval_spec.md (Q1/main-alert analytic); executable form formalised under alert-anchor policy v1.0"
  },
  "scope": {
    "basis": "declared_asset_scope",
    "complete_legal_scope": true,
    "description": "All events in the configured raw source after any pre-existing host and sensor scope is applied."
  },
  "event_predicate": {
    "all": [
      {
        "field": "event_code",
        "op": "eq",
        "value": 1
      },
      {
        "field": "attributes.image",
        "op": "iendswith",
        "value": "\\reg.exe"
      },
      {
        "field": "attributes.command_line",
        "op": "regex",
        "value": "(?i)\\badd\\b"
      },
      {
        "field": "attributes.command_line",
        "op": "icontains",
        "value": "\\CurrentVersion\\Winlogon"
      },
      {
        "field": "attributes.command_line",
        "op": "icontains",
        "value": "DefaultUserName"
      }
    ]
  },
  "selection": {
    "strategy": "earliest_match"
  },
  "expected_a0": {
    "record_key": "48598"
  },
  "rationale": "A command that writes Winlogon DefaultUserName is a reproducible credential and autologon configuration alert."
}
