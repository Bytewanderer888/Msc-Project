{
  "schema_version": "1.0",
  "case_id": "RK-001",
  "rule_id": "SAFESOC-TRG-RK-001",
  "analytic_family_id": "AF-REG",
  "analytic_pattern_id": "REG-01",
  "title": "Run-key registry value creation",
  "formalisation_timing": "retrospective_pre_extension_audit",
  "rule_origin": {
    "type": "project_analytic",
    "reference": "queries/retrieval_spec.md (Q1/main-alert analytic); executable form formalised under alert-anchor policy v1.0"
  },
  "scope": {
    "basis": "full_source",
    "complete_legal_scope": true,
    "description": "All events in the configured raw source; no event-level answer selector is applied."
  },
  "event_predicate": {
    "all": [
      {
        "field": "event_code",
        "op": "eq",
        "value": 13
      },
      {
        "field": "attributes.target_object",
        "op": "regex",
        "value": "(?i)\\\\Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Run\\\\[^\\\\]+$"
      },
      {
        "field": "attributes.registry_event",
        "op": "ieq",
        "value": "SetValue"
      }
    ]
  },
  "selection": {
    "strategy": "earliest_match"
  },
  "expected_a0": {
    "record_key": "4430"
  },
  "rationale": "Creating a value beneath a user Run key is a stable registry-persistence alert surface."
}
