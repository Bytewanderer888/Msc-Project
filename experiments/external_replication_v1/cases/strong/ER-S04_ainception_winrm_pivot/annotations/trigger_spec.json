{
  "schema_version": "1.0",
  "case_id": "ER-S04",
  "rule_id": "SAFESOC-TRG-ER-S04",
  "analytic_family_id": "AF-PROC",
  "analytic_pattern_id": "PROC-03",
  "title": "High-integrity remote-management executable starts from Downloads",
  "formalisation_timing": "prospective_pre_model",
  "rule_origin": {
    "type": "project_analytic",
    "reference": "external_replication_v1 pre-model alert-anchor review under policy v1.0"
  },
  "scope": {
    "basis": "source_defined_step",
    "complete_legal_scope": true,
    "description": "Every record in the corpus-provided log member or scenario step containing the alert stream.",
    "source_units": [
      "SL100/sl100-raw-data/2nd Data Extraction_with_suricata_netflows/WSUS.txt"
    ]
  },
  "event_predicate": {
    "all": [
      {
        "field": "event_code",
        "op": "eq",
        "value": 1
      },
      {
        "field": "attributes.raw_text",
        "op": "regex",
        "value": "(?i)\\\\Users\\\\[^\\\\]+\\\\Downloads\\\\[^\\r\\n]*(?:psremoting|winrm|remote)[^\\r\\n]*\\.exe"
      },
      {
        "field": "attributes.raw_text",
        "op": "regex",
        "value": "(?im)^High\\s*$"
      }
    ]
  },
  "selection": {
    "strategy": "earliest_match"
  },
  "expected_a0": {
    "record_key": "SL100/sl100-raw-data/2nd Data Extraction_with_suricata_netflows/WSUS.txt:block:77"
  },
  "rationale": "A high-integrity executable whose filename identifies remote-management behaviour starting from Downloads is a pivot alert; cross-host execution is established by context."
}
