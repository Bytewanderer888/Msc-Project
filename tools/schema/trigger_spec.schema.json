{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SafeSOC alert-anchor trigger specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "rule_id",
    "analytic_family_id",
    "analytic_pattern_id",
    "title",
    "formalisation_timing",
    "rule_origin",
    "scope",
    "event_predicate",
    "selection",
    "expected_a0",
    "rationale"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "case_id": {"type": "string", "minLength": 1},
    "rule_id": {"type": "string", "pattern": "^SAFESOC-TRG-[A-Z0-9-]+$"},
    "analytic_family_id": {"type": "string", "pattern": "^AF-[A-Z]+$"},
    "analytic_pattern_id": {"type": "string", "pattern": "^[A-Z]+-[0-9]{2}$"},
    "title": {"type": "string", "minLength": 8},
    "formalisation_timing": {
      "enum": ["retrospective_pre_extension_audit", "prospective_pre_model"]
    },
    "rule_origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "reference"],
      "properties": {
        "type": {"enum": ["project_analytic", "published_analytic_adaptation"]},
        "reference": {"type": "string", "minLength": 1}
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "complete_legal_scope", "description"],
      "properties": {
        "basis": {"enum": ["full_source", "source_defined_step", "declared_asset_scope"]},
        "complete_legal_scope": {"const": true},
        "description": {"type": "string", "minLength": 8},
        "source_units": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "filter_predicate": {"$ref": "#/definitions/expression"}
      }
    },
    "event_predicate": {"$ref": "#/definitions/expression"},
    "aggregation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["group_by", "count_gte"],
      "properties": {
        "group_by": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "count_gte": {"type": "integer", "minimum": 2},
        "within_seconds_lte": {"type": "number", "exclusiveMinimum": 0},
        "session_gap_seconds_lte": {"type": "number", "exclusiveMinimum": 0},
        "distinct": {
          "type": "object",
          "additionalProperties": false,
          "required": ["field", "count_gte"],
          "properties": {
            "field": {"type": "string", "minLength": 1},
            "count_gte": {"type": "integer", "minimum": 2}
          }
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy"],
      "properties": {
        "strategy": {
          "enum": ["earliest_match", "latest_match", "earliest_in_highest_count_group"]
        },
        "justification": {"type": "string", "minLength": 12}
      }
    },
    "expected_a0": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_key"],
      "properties": {
        "record_key": {"type": "string", "minLength": 1},
        "record_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "rationale": {"type": "string", "minLength": 20}
  },
  "definitions": {
    "expression": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/definitions/expression"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/definitions/expression"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["not"],
          "properties": {"not": {"$ref": "#/definitions/expression"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["field", "op", "value"],
          "properties": {
            "field": {"type": "string", "minLength": 1},
            "op": {
              "enum": [
                "eq",
                "ieq",
                "contains",
                "icontains",
                "startswith",
                "istartswith",
                "endswith",
                "iendswith",
                "regex",
                "in"
              ]
            },
            "value": {}
          }
        }
      ]
    }
  }
}
